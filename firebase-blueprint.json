{
  "entities": {
    "User": {
      "title": "User",
      "description": "Core user profile and account status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["vc", "startup", "admin"] },
        "status": { "type": "string", "enum": ["waitlisted", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "fullName", "role", "status"]
    },
    "VCProfile": {
      "title": "VC Profile",
      "description": "Detailed information for Capital Providers",
      "type": "object",
      "properties": {
        "firmName": { "type": "string" },
        "firmWebsite": { "type": "string" },
        "bio": { "type": "string" },
        "stage": { "type": "string" },
        "minCheck": { "type": "number" },
        "maxCheck": { "type": "number" },
        "industries": { "type": "array", "items": { "type": "string" } },
        "linkedin": { "type": "string" },
        "previousInvestments": { "type": "string" }
      }
    },
    "StartupProfile": {
      "title": "Startup Profile",
      "description": "Detailed information for Company Founders",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "companyWebsite": { "type": "string" },
        "bio": { "type": "string" },
        "industry": { "type": "string" },
        "stage": { "type": "string" },
        "amountRaising": { "type": "number" },
        "pitchDeckUrl": { "type": "string" },
        "pitchVideoUrl": { "type": "string" },
        "founderName": { "type": "string" },
        "founderLinkedin": { "type": "string" },
        "availability": {
          "type": "object",
          "properties": {
            "days": { "type": "array", "items": { "type": "string" } },
            "slots": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "Swipe": {
      "title": "Swipe",
      "description": "VC interest in a startup",
      "type": "object",
      "properties": {
        "vcId": { "type": "string" },
        "startupId": { "type": "string" },
        "direction": { "type": "string", "enum": ["right", "left"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between a VC and a Startup",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Meeting": {
      "title": "Meeting",
      "description": "A scheduled meeting between VC and Startup",
      "type": "object",
      "properties": {
        "vcId": { "type": "string" },
        "startupId": { "type": "string" },
        "slot": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "meetingLink": { "type": "string" },
        "fineAccepted": { "type": "boolean" }
      }
    },
    "HungryInvestor": {
      "title": "Hungry Investor Opportunity",
      "description": "VC posting for specific investment interests",
      "type": "object",
      "properties": {
        "vcId": { "type": "string" },
        "title": { "type": "string" },
        "industry": { "type": "string" },
        "stage": { "type": "string" },
        "checkSize": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User accounts and status" },
    "vcs": { "schema": "VCProfile", "description": "VC specific data" },
    "startups": { "schema": "StartupProfile", "description": "Startup specific data" },
    "swipes": { "schema": "Swipe", "description": "VC swiping history" },
    "chats": { "schema": "Chat", "description": "Active conversations" },
    "messages": { "schema": "Message", "description": "Chat messages" },
    "meetings": { "schema": "Meeting", "description": "Scheduled meetings" },
    "hungryInvestors": { "schema": "HungryInvestor", "description": "Investment opportunities" }
  }
}
